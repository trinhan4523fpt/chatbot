# Copy to .env (gitignored) and adjust. docker-compose reads these.

# SQL Server SA password (dev container only). Must meet SQL complexity rules.
# Keep this in sync with the dev connection string in src/Chatbot.Api/appsettings.Development.json.
MSSQL_SA_PASSWORD=Chatbot_Dev_P@ssw0rd1

# Shared key for .NET <-> Python ML service calls (X-Internal-Key header).
INTERNAL_API_KEY=dev-internal-key-change-me

# Ollama chat model pulled by ollama-init (Vietnamese-capable). Fallback: llama3.1:8b
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct

# Optional: enables the OpenAI embedding model + report-grade RAGAS judge in the
# benchmark. Leave empty to run free/local only (OpenAI runs are marked "skipped").
OPENAI_API_KEY=
