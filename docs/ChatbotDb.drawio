        <mxCell id="lgn" value="Ghi chu:&#10;- PK = khoa chinh, FK = khoa ngoai&#10;- Cascade = xoa cha thi xoa con&#10;- Restrict = chan xoa neu con tham chieu&#10;- SetNull (net dut) = xoa cha thi con = NULL&#10;- Vector THAT nam o Qdrant, khong o SQL.&#10;  ChunkEmbedding chi luu dia chi (collection + point id)&#10;- Bang hangfire.* do Hangfire tu tao, khong ve o day&#10;- Cac bang co IsDeleted dung soft-delete" style="text;align=left;verticalAlign=top;fontSize=11;spacingLeft=8;spacingTop=6;fillColor=#ffffff;strokeColor=#999999;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="2280" y="282" width="250" height="175" as="geometry"/></mxCell>
